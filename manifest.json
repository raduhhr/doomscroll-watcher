{
  "manifest_version": 3,
  "name": "Doomscroll Punisher",
  "version": "0.3.0",
  "description": "Blocks scrolling on Instagram, LinkedIn, Facebook, and YouTube Shorts and interrupts doomscrolling with a timed warning modal.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://instagram.com/*",
        "*://*.instagram.com/*",
        "*://linkedin.com/*",
        "*://*.linkedin.com/*",
        "*://facebook.com/*",
        "*://*.facebook.com/*",
        "*://youtube.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "shame-data.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "sounds/*"
      ],
      "matches": [
        "*://instagram.com/*",
        "*://*.instagram.com/*",
        "*://linkedin.com/*",
        "*://*.linkedin.com/*",
        "*://facebook.com/*",
        "*://*.facebook.com/*",
        "*://youtube.com/*",
        "*://*.youtube.com/*"
      ]
    }
  ]
}
